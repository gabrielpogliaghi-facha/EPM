# ── VARIABLES DE ENTORNO — EPM Sistema de Gestión Escolar ─────────────────────
# Copiá este archivo como .env y completá con tus valores reales.
# NUNCA subas el archivo .env al repositorio.

# Puerto del servidor
# Render.com asigna su propio puerto automáticamente — no cambies esto.
PORT=3001

# Clave secreta para firmar los tokens JWT de sesión.
# Debe ser una cadena larga, aleatoria y única. Generá una con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria-de-al-menos-32-caracteres

# Duración de la sesión de usuario
JWT_EXPIRES_IN=24h

# ── BASE DE DATOS (Turso / libSQL) ────────────────────────────────────────────
# Desarrollo (SQLite local): dejar sin definir → usa file:./epm.db automáticamente
# TURSO_URL=file:./epm.db
# TURSO_AUTH_TOKEN=

# Producción (Turso en la nube): configurar ambas variables en Render → Settings → Environment
# TURSO_URL=libsql://tu-db.aws-ap-northeast-1.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...tu_token_aqui

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
# API key de Resend para envío de emails (recuperación de contraseña, etc.)
# Obtené tu key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Entorno
NODE_ENV=production
